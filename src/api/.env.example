# ╔══════════════════════════════════════════════════════════╗
# ║  src/api/.env.example — Template cấu hình backend        ║
# ║  Sao chép thành src/api/.env rồi điền giá trị thực      ║
# ║  KHÔNG commit file .env vào git                          ║
# ╚══════════════════════════════════════════════════════════╝

# ──────────────────────────────────────────────────
# LLM — LM Studio (OpenAI-compatible endpoint)
# ──────────────────────────────────────────────────

# Base URL của LM Studio server (local hoặc Cloudflare tunnel)
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# API key cho LM Studio (mặc định là bất kỳ chuỗi nào)
LM_STUDIO_API_KEY=lm-studio

# Tên model đang chạy trong LM Studio
LM_MODEL=qwen/qwen3-8b

# ──────────────────────────────────────────────────
# VECTOR DATABASE — Qdrant
# ──────────────────────────────────────────────────

# URL của Qdrant server
QDRANT_URL=http://localhost:6333

# Tên collection chứa dữ liệu pháp luật
QDRANT_COLLECTION=luat_giao_thong_new_finetune_model

# ──────────────────────────────────────────────────
# MODELS — Embedding & Reranker
# ──────────────────────────────────────────────────

# Đường dẫn tương đối hoặc tuyệt đối đến embedding model
EMBEDDING_MODEL_PATH=./nrk-legal-large-traffic-ft-merged-v2

# Tên hoặc đường dẫn reranker model (HuggingFace hub hoặc local)
RERANKER_MODEL_NAME=AITeamVN/Vietnamese_Reranker

# ──────────────────────────────────────────────────
# GRAPH DATABASE — Neo4j
# ──────────────────────────────────────────────────

# URI kết nối Neo4j
NEO4J_URI=bolt://localhost:7687

# Tài khoản Neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
